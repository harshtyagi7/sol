# ============================================================
# Sol Trading System - Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# --- Zerodha Kite Connect ---
KITE_API_KEY=your_kite_api_key_here
KITE_API_SECRET=your_kite_api_secret_here
KITE_REDIRECT_URL=http://localhost:8000/api/auth/callback

# --- LLM API Keys ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here          # Required only if using GPT-4 agents
GOOGLE_API_KEY=your_google_api_key_here          # Required only if using Gemini agents

# --- News (optional) ---
# FINNHUB_API_KEY=your_key_here   # Better news quality; free tier at https://finnhub.io
# If not set, falls back to Economic Times + Moneycontrol RSS feeds (no key needed)

# --- Database ---
DATABASE_URL=postgresql+asyncpg://sol:solpass@localhost:5432/soldb
REDIS_URL=redis://localhost:6379

# --- Security ---
SECRET_KEY=generate-a-strong-random-secret-key-here-minimum-32-chars
# Your Zerodha client ID. Only this account can log in. All others are rejected.
ALLOWED_KITE_USER_ID=YU5831

# --- Trading Mode ---
# IMPORTANT: Set to False only when you are ready for live trading.
# In paper mode, no real orders are placed. All trades are simulated.
PAPER_TRADING_MODE=True

# --- Risk Defaults (can be overridden via dashboard) ---
MAX_CAPITAL_PCT=2.0           # Max % of capital at risk per trade
DAILY_LOSS_LIMIT_PCT=5.0      # Max daily loss as % of capital before trading stops
MAX_OPEN_POSITIONS=5          # Maximum simultaneous open positions
MAX_POSITION_SIZE_PCT=10.0    # Max single stock allocation as % of capital

# --- App Settings ---
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
